        <!-- C4: Create Donation Order (Razorpay Integration) -->
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="C4 - POST /api/donations/create-order [Razorpay Init]" enabled="true">
          <boolProp name="HTTPSampler.postBodyRaw">true</boolProp>
