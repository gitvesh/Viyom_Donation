      <ResultCollector guiclass="StatVisualizer" testclass="ResultCollector" testname="[GLOBAL] Aggregate Report - All Scenarios" enabled="true">
        <boolProp name="ResultCollector.error_logging">false</boolProp>
        <objProp>
          <name>saveConfig</name>
          <value class="SampleSaveConfiguration">
            <time>true</time>
