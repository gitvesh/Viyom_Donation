# ─────────────────────────────────────────────────────────────────────────────
# Blockchain: Polygon Amoy Testnet Configuration
# Copy this file to .env and fill in the real values.  DO NOT commit .env.
# ─────────────────────────────────────────────────────────────────────────────

# ⚠️  PRIVATE_KEY must be your wallet's PRIVATE KEY – 64 lowercase hex characters.
#     It is NOT your wallet address (which is only 40 hex chars).
#     Example format: abcdef1234567890abcdef1234567890abcdef1234567890abcdef1234567890
PRIVATE_KEY=YOUR_64_HEX_PRIVATE_KEY_HERE

# Alchemy RPC endpoint for Polygon Amoy testnet
AMOY_RPC_URL=https://polygon-amoy.g.alchemy.com/v2/Ecooto5QXtLA10_XTBtIN

# Polygon Mainnet RPC (for future production)
POLYGON_RPC_URL=https://polygon-rpc.com

# Optional: Polygonscan API Key for automatic contract verification after deploy
POLYGONSCAN_API_KEY=SBZXRR7QQUFP2V5FME7EDJN69C539M8U24