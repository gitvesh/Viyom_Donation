      "name": "1. Fund Allocation Operations",
      "item": [
        {
          "name": "Create Fund Allocation",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{admin_jwt_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"poolId\": 1,\n  \"beneficiaryId\": 1,\n  \"amount\": 5000.00,\n  \"purpose\": \"School Supplies for Q3 2025\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/admin/fund-allocate",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "fund-allocate"]
            }
          },
          "response": []
        },
        {
          "name": "Create Fund Allocation - Large Amount",
